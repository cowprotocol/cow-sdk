{
  "$schema": "https://turbo.build/schema.json",
  "concurrency": "20",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:coverage": {
      "outputs": ["coverage/**"],
      "dependsOn": ["build"],
      "cache": true
    },
    "test:coverage:html": {
      "outputs": ["coverage/**"],
      "dependsOn": ["build"],
      "cache": true
    },
    "coverage:badges": {
      "dependsOn": ["test:coverage"],
      "outputs": ["README.md"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "swagger:codegen": {
      "cache": false
    },
    "typecheck": {
      "outputs": [],
      "cache": true,
      "dependsOn": ["build"]
    }
  }
}
